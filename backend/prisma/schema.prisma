datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  STAFF
  CUSTOMER
}

enum VoucherType {
  FIXED
  PERCENT
  FREESHIP
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  COD
  MOMO
  ZALOPAY
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String
  role         Role      @default(CUSTOMER)
  points       Int       @default(0)
  totalSpent   Float     @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  isDeleted    Boolean   @default(false)
  orders       Order[]

  @@index([email])
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id               String      @id @default(uuid())
  name             String
  description      String
  price            Float
  salePrice        Float?
  image            String
  images           String[]
  category         Category    @relation(fields: [categoryId], references: [id])
  categoryId       String
  sizes            String[]
  colors           String[]
  stock            Int         @default(0)
  materials        String[]
  careInstructions String?
  tags             String[]
  isNew            Boolean     @default(true)
  rating           Float       @default(5.0)
  isDeleted        Boolean     @default(false)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  orderItems       OrderItem[]
  reviews          Review[]

  @@index([categoryId])
}

model Order {
  id             String        @id @default(uuid())
  user           User          @relation(fields: [userId], references: [id])
  userId         String
  subtotal       Float
  shippingFee    Float         @default(30000)
  discountAmount Float         @default(0)
  finalTotal     Float
  voucherCode    String?
  status         OrderStatus   @default(PENDING_PAYMENT)
  paymentMethod  PaymentMethod @default(COD)
  shippingAddress String
  recipientName  String
  recipientPhone String
  recipientEmail String
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  orderItems     OrderItem[]

  @@index([userId])
}

model OrderItem {
  id        String   @id @default(uuid())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  quantity  Int
  size      String
  color     String
  price     Float
  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([productId])
}

model Review {
  id        String   @id @default(uuid())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  name      String
  rating    Int
  content   String
  createdAt DateTime @default(now())

  @@index([productId])
}

model Voucher {
  id         String      @id @default(uuid())
  code       String      @unique
  type       VoucherType
  value      Float
  minOrder   Float       @default(0)
  usageLimit Int         @default(100)
  usedCount  Int         @default(0)
  status     String      @default("active")
  expiresAt  DateTime
  isWelcome  Boolean     @default(false)
  createdAt  DateTime    @default(now())

  @@index([code])
}
